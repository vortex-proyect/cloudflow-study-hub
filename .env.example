# Cloudflare Bindings (Configure these in Cloudflare Dashboard -> Pages -> Settings -> Variables)
# -------------------------------------------------------------------------------------
# The following are NOT standard environment variables but Cloudflare Bindings.
# They must be linked in the Cloudflare Dashboard for the app to function.

# D1 Database Binding
DB=cloudflow-db

# R2 Bucket Binding
BUCKET=cloudflow-docs-storage

# Vectorize Index Binding
VECTOR_INDEX=cloudflow-embeddings-index

# Workers AI Binding
AI=AI_BINDING

# GitHub Secrets for CI/CD (Add these to GitHub Repo Settings -> Secrets and Variables -> Actions)
# -------------------------------------------------------------------------------------
# CLOUDFLARE_API_TOKEN=your_api_token_here
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here
